# -------------------------------
# Supabase Configuration
# -------------------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -------------------------------
# AI Configuration
# -------------------------------
AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key

# -------------------------------
# Application
# -------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Smart Emergency Guide

# -------------------------------
# Contact Information
# -------------------------------
NEXT_PUBLIC_CONTACT_WHATSAPP=+962796959573
NEXT_PUBLIC_CONTACT_EMAIL=kisscrisis@proton.com
NEXT_PUBLIC_CONTACT_WEBSITE=https://smartemergencyguide.com

# -------------------------------
# Content Protection
# -------------------------------
NEXT_PUBLIC_ENABLE_WATERMARK=true
NEXT_PUBLIC_ENABLE_BLUR_ON_TAB_SWITCH=true
NEXT_PUBLIC_ENABLE_ANTI_COPY=true
