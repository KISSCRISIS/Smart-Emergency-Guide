  "drugList": [
    {
      "name": "Adenosine",
      "use": "SVT (supraventricular tachycardia)",
      "dose": "6mg IV rapid push, then 12mg if needed",
      "contraindications": "WPW with AF (may cause VF), second/third-degree AV block"
    },
    {
      "name": "Amiodarone",
      "use": "Ventricular tachycardia, atrial fibrillation",
      "dose": "300mg IV for VT, 150mg over 10 min for AF",
      "contraindications": "Hypotension, bradycardia, thyroid disease, pulmonary fibrosis history"
    },
    {
      "name": "Aspirin",
      "use": "Acute coronary syndrome (ACS)",
      "dose": "162-325 mg chewed",
      "contraindications": "Active bleeding, aspirin allergy"
    },
    {
      "name": "Atropine",
      "use": "Symptomatic bradycardia, organophosphate poisoning",
      "dose": "0.5-1 mg IV q3-5 min (max 3 mg)",
      "contraindications": "Avoid in hypothermic bradycardia"
    },
    {
      "name": "Ceftriaxone",
