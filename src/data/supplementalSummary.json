{
  "summaryData": [
    {
      "id": "resuscitation",
      "title": "🫁 الإنعاش المتقدم",
      "content": [
        {
          "sub": "إدارة مجرى التنفس (RSI)",
          "eng": "RSI steps: Preparation, Preoxygenation, Paralysis (Succinylcholine 1.5mg/kg or Rocuronium 1.2mg/kg).",
          "arabic": "خطوات التنبيب السريع: تحضير، أكسجة، شلل عضلي.",
          "quick": {
            "symptoms": "Stridor, inability to handle secretions",
            "diagnosis": "Clinical assessment",
            "treatment": "RSI with appropriate paralytic"
          }
        },
        {
          "sub": "ACLS",
          "eng": "Shockable rhythms: defibrillate, epinephrine, amiodarone.",
          "arabic": "النظم القابلة للصدمة: صدمة، إبينفرين، أميودارون.",
          "quick": {
            "symptoms": "Unresponsiveness, apnea",
            "diagnosis": "ECG",
            "treatment": "CPR, defibrillation, epinephrine"
          }
        }
      ]
    },
    {
      "id": "ventilation",
      "title": "🫀 التنفس الصناعي",
      "content": [
        {
          "sub": "المودات والإعدادات",
          "eng": "Modes: AC/VC, PC, PSV, SIMV, PRVC, APRV, HFOV.",
          "arabic": "المودات: تحكم مساعد، تحكم بالضغط، دعم ضغط، إلخ.",
          "quick": {
            "symptoms": "Respiratory failure",
            "diagnosis": "ABG",
            "treatment": "Set Vt 6-8 mL/kg, PEEP 5-8"
          }
        }
      ]
    },
